<?xml version='1.0' encoding='UTF-8'?>
<deployment-plan xmlns="http://xmlns.oracle.com/weblogic/deployment-plan" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://xmlns.oracle.com/weblogic/deployment-plan http://xmlns.oracle.com/weblogic/deployment-plan/1.0/deployment-plan.xsd">
  <application-name>IST-Monitoring</application-name>
  <variable-definition>
    <variable>
      <name>ServletDescriptor_MessageBrokerServlet_ServletName_13613173157310</name>
      <value>MessageBrokerServlet</value>
    </variable>
    <variable>
      <name>ServletDescriptor_PDFExportServlet_ServletName_13613173157471</name>
      <value>PDFExportServlet</value>
    </variable>
    <variable>
      <name>WeblogicWebApp_ContextRoots_13613174294324</name>
      <value>"istgn"</value>
    </variable>
    <variable> 
      <name>ProtectedDirectoryPath</name>
      <value>/enc/sw/prot_dir</value>
    </variable>
    <variable>
      <name>ResourceDescription_jdbc/t21_JNDIName_160712097333976</name>
      <value>jdbc/t21</value>
    </variable>
	<variable>
      <name>ResourceDescription_jdbc/ist_JNDIName_160712097333355</name>
      <value>jdbc/ist</value>
    </variable>
    <variable>
      <name>ResourceDescription_jdbc/ist_audit_JNDIName_160712097332326</name>
      <value>jdbc/ist_audit</value>
    </variable>    
    <variable>
      <name>ResourceDescription_jdbc/ist_ent_JNDIName_160712097334491</name>
      <value>jdbc/ist_ent</value>
    </variable>
  </variable-definition>
  <module-override>
    <module-name>IST-Monitoring.war</module-name>
    <module-type>war</module-type>
    <module-descriptor external="false">
      <root-element>weblogic-web-app</root-element>
      <uri>WEB-INF/weblogic.xml</uri>
      <variable-assignment>
        <name>ServletDescriptor_MessageBrokerServlet_ServletName_13613173157310</name>
        <xpath>/weblogic-web-app/servlet-descriptor/[servlet-name="MessageBrokerServlet"]/servlet-name</xpath>
        <origin>planbased</origin>
      </variable-assignment>
      <variable-assignment>
        <name>ServletDescriptor_PDFExportServlet_ServletName_13613173157471</name>
        <xpath>/weblogic-web-app/servlet-descriptor/[servlet-name="PDFExportServlet"]/servlet-name</xpath>
        <origin>planbased</origin>
      </variable-assignment>
      <variable-assignment>
        <name>WeblogicWebApp_ContextRoots_13613174294324</name>
        <xpath>/weblogic-web-app/context-root</xpath>
        <operation>replace</operation>
      </variable-assignment>
      <variable-assignment>
        <name>ResourceDescription_jdbc/t21_JNDIName_160712097333976</name>
        <xpath>/weblogic-web-app/resource-description/[res-ref-name="jdbc/t21"]/jndi-name</xpath>
        <origin>planbased</origin>
      </variable-assignment>
      <variable-assignment>
        <name>ResourceDescription_jdbc/ist_JNDIName_160712097333355</name>
        <xpath>/weblogic-web-app/resource-description/[res-ref-name="jdbc/ist"]/jndi-name</xpath>
        <origin>planbased</origin>
      </variable-assignment>
     <variable-assignment>
        <name>ResourceDescription_jdbc/ist_audit_JNDIName_160712097332326</name>
        <xpath>/weblogic-web-app/resource-description/[res-ref-name="jdbc/ist_audit"]/jndi-name</xpath>
        <origin>planbased</origin>
      </variable-assignment>
      <variable-assignment>
        <name>ResourceDescription_jdbc/ist_ent_JNDIName_160712097334491</name>
        <xpath>/weblogic-web-app/resource-description/[res-ref-name="jdbc/ist_ent"]/jndi-name</xpath>
        <origin>planbased</origin>
      </variable-assignment>      
    </module-descriptor>
    <module-descriptor external="false">
      <root-element>web-app</root-element>
      <uri>WEB-INF/web.xml</uri>
      <variable-assignment>
      <name>ProtectedDirectoryPath</name>
      <xpath>/web-app/env-entry/[env-entry-name="ProtectedDirectoryPath"]/env-entry-value</xpath>
      <operation>add</operation>
      </variable-assignment> 
    </module-descriptor>
    <module-descriptor external="true">
      <root-element>wldf-resource</root-element>
      <uri>META-INF/weblogic-diagnostics.xml</uri>
    </module-descriptor>
  </module-override>
  <config-root>/enc/ist-root/app</config-root>
</deployment-plan>
